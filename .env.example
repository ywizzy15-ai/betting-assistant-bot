# ==========================================
# TELEGRAM BOT CONFIGURATION
# ==========================================
# Get this from @BotFather on Telegram
BOT_TOKEN=your_telegram_bot_token_here

# Comma-separated Telegram User IDs for admin access
# Find your ID via @userinfobot on Telegram
ADMIN_IDS=123456789,987654321

# ==========================================
# RENDER & SERVER CONFIGURATION
# ==========================================
# Render automatically injects this. Leave empty for local dev.
RENDER_EXTERNAL_URL=

# Local dev port (Render overrides this automatically)
PORT=8080

# ==========================================
# AI & EXTERNAL API KEYS
# ==========================================
# GROQ API Key (Llama 3.3 70B for divergence analysis)
# Get free tier at https://console.groq.com/
GROQ_API_KEY=

# football-data.org API Key (Optional: used for live fixtures/results later)
# Get free tier at https://www.football-data.org/client/register
FOOTBALL_DATA_KEY=

# ==========================================
# SECURITY NOTES
# ==========================================
# 1. NEVER commit this file with real values to GitHub
# 2. On Render, paste these under Environment > Add Environment Variable
# 3. Local dev: rename to .env and fill values
# 4. ADMIN_IDS must be integers separated by commas (no spaces)

